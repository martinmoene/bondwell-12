  487	  020B    1E 0A                 	ld	e,lf
  488	  020D    CD 0005               	call	bdos
  489	                                
  490	  0210    3A 021B               	ld	a,(fopt)		; option '-F' used?
  491	  0213    FE 01                 	cp	true
  492	  0215    C8                    	ret	z			;   yes: return to CCP
  493	  0216    C3 0000               	jp	0			;   no: warmboot; to see dir. again
