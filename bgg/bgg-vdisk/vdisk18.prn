  529	                                
  530	                                ;---------------------------------------------------------------- Vdbios ------
  531	                                ;
  532	                                ; Vdbios	 Virtual-disk BIOS routines.
  533	                                ;
  534	                                
  535	  022E                          vdbiosl:.phase	vdaddr		; phase addresses to high memory
  536	                                
  537	  F500                          vdbios	equ	$
  538	                                
  539	                                ;
  540	                                ; Addresses of old Bondwell 12 CP/M 2.2 bios routines.
  541	                                ;
  542	                                				
  543	  EE90                          oseldsk equ	0ee90H		; seldsk 
  544	  EEE8                          osettrk equ	0eee8H          ; settrk 
  545	  EEED                          osetsec equ	0eeedH          ; setsec 
  546	  EEF2                          osetdma equ	0eef2H          ; setdma 
  547	  EEF8                          oread	equ	0eef8H          ; read   
  548	  EF0A                          owrite	equ	0ef0aH          ; write  
  549	                                                                         
  550	                                
  551	                                ;
  552	                                ; Parameters of DPH and DPB
  553	                                ;
  554	                                
  555	  0000                          xlt	equ	0000		; no sector translation
  556	  0100                          spt	equ	256		; 256 sectors / track
  557	  0004                          bsh	equ	4		; allocation blocksize = 2048
  558	  000F                          blm	equ	15		;  ..
  559	  0800                          bls	equ	2048		;  ..
  560	  0080                          al0	equ	80H		; 1 reserved block for DIR.
  561	  0000                          al1	equ	00
  562	  0000                          off	equ	0		; no offset tracks
  563	  003F                          drm	equ 	63		; 63: # dir. entries-1
  564	  007F                          dsm	equ	vdsize/(bls/1024)-1	; capacity
  565	  0000                          cks	equ	0		; (drm+1)/4; directory check vector
  566	  0001                          exm	equ	1		; extent mask
  567	                                
  568	  0002                          dirsiz	equ	(drm+1)*32/1024	; directory size (kbyte)
  569	                                
  570	                                
  571	                                ;
  572	                                ; Virtual-Disk Parameter Header:
  573	                                ;
  574	                                
  575	  F500    0000                  vdph:	dw	xlt
  576	  F502    0000 0000             	dw	0000,0000,0000
  577	  F506    0000                  
  578	  F508    F2CD                  	dw	dirbuf
  579	  F50A    F510                  	dw	vdpb
  580	  F50C    0000                  	dw	csv
  581	  F50E    F620                  	dw	alv
  582	                                
  583	                                
  584	                                ;
  585	                                ; Virtual-Disk parameter Block:
  586	                                ;
  587	                                
  588	  F510    0100                  vdpb:	dw	spt
  589	  F512    04 0F                 	db	bsh,blm
  590	  F514    01                    	db	exm
  591	  F515    007F                  	dw	dsm
  592	  F517    003F                  	dw	drm
  593	  F519    80 00                 	db	al0,al1
  594	  F51B    0000                  	dw	cks
  595	  F51D    0000                  	dw	off
  596	                                
  597	                                
  598	                                	SUBTTL	Virtual-Disk: [BIOS.routines]
  599	                                	PAGE
VDISK	MACRO-80 3.44	09-Dec-81	PAGE	1-11
Virtual-Disk: [BIOS.routines]

  600	                                
  601	                                ;--------------------------------------------------------- BIOS routines ------
  602	                                ;
  603	                                ; BIOS routines
  604	                                ;
  605	                                
  606	                                ;------------------------------------------------------ VD warmboot-tail ------
  607	                                ;
  608	                                ; vdwbt
  609	                                ;
  610	                                ;	Virtual disk warmboot tail
  611	                                ;	Check for current drive = virtual disk
  612	                                ;
  613	                                
  614	  0004                          curdsk	equ	4		; address of current user/disk code
  615	                                
  616	  F51F    41                    vdwbt:	ld	b,c		; save drive code
  617	  F520    3A 0004               	ld	a,(curdsk)	; get current drive
  618	  F523    FE 02                 	cp	vd		; Virtual disk?
  619	  F525    4F                    	ld	c,a		;   code in reg c
  620	  F526    28 01                 	jr	z,vdwbt1	;   yes: send vd-code to CCP
  621	  F528    48                    	ld	c,b		; restore drive code
  622	  F529    C3 D403               vdwbt1:	jp	ccp		; continue in CCP
  623	                                
  624	                                
  625	                                ;---------------------------------------------------------------- Seldsk ------
  626	                                ;
  627	                                ; Seldsk
  628	                                ;
  629	                                ;	input:
  630	                                ;		Reg.c: 	drive
  631	                                ;	output:
  632	                                ;		Reg.hl:	vdph address
  633	                                ;
  634	                                
  635	  F52C    C5                    seldsk:	push	bc
  636	  F52D    47                    	ld	b,a			; save reg.a and c
  637	  F52E    79                    	ld	a,c			; a:=drive nbr.
  638	  F52F    32 F6B0               	ld	(drive),a		; drive nbr.
  639	  F532    FE 02                 	cp	vd			; drive = 'C'?
  640	  F534    78                    	ld	a,b			;     (restore Reg.a)
  641	  F535    C1                    	pop	bc			;     (restore Reg.bc)
  642	  F536    C2 EE90               	jp	nz,oseldsk		;   no: jump to old bios tabel
  643	  F539    21 F500               	ld	hl,vdph			;   yes: hl = vdph address
  644	  F53C    C9                    	ret				; return
  645	                                
  646	                                
  647	                                ;---------------------------------------------------------------- Settrk ------
  648	                                ;
  649	                                ; Settrk 
  650	                                ;
  651	                                ;	input:
  652	                                ;		Reg.bc:	track
  653	                                ;	output:
  654	                                ;		none
  655	                                ;
  656	                                
  657	  F53D    ED 43 F6B1            settrk:	ld	(track),bc		;tracknr. in track
  658	  F541    C3 EEE8               	jp	osettrk			; continue in original routine
  659	                                
  660	                                
  661	                                
  662	                                ;---------------------------------------------------------------- Setsec ------
  663	                                ;
  664	                                ; Setsec 
  665	                                ;
  666	                                ;	input:
  667	                                ;		Reg.bc:	sector
  668	                                ;	output:
  669	                                ;		none
  670	                                ;
  671	                                
  672	  F544    ED 43 F6B3            setsec:	ld	(sector),bc		;sectornr in sector
  673	  F548    C3 EEED               	jp	osetsec			;continue in original routine
  674	                                
  675	                                
  676	                                
  677	                                ;---------------------------------------------------------------- Setdma ------
  678	                                ;
  679	                                ; Setdma 
  680	                                ;
  681	                                ;	input:
  682	                                ;		Reg.bc:	dma address
VDISK	MACRO-80 3.44	09-Dec-81	PAGE	1-12
Virtual-Disk: [BIOS.routines]

  683	                                ;	output:
  684	                                ;		none
  685	                                ;
  686	                                
  687	  F54B    ED 43 F6B5            setdma:	ld	(dma),bc		;dma address in dma
  688	  F54F    C3 EEF2               	jp	osetdma			;continue in original routine
  689	                                
  690	                                	PAGE
VDISK	MACRO-80 3.44	09-Dec-81	PAGE	1-13
Virtual-Disk: [BIOS.routines]

  691	                                
  692	                                ;------------------------------------------------------------------ Read ------
  693	                                ;
  694	                                ; Read
  695	                                ;
  696	                                ;	input:	none
  697	                                ;	output:	none
  698	                                ;
  699	                                
  700	  F552    CD F5A8               read:	call	checkd			; drive C:?
  701	  F555    C2 EEF8               	jp	nz,oread		;   no: old jump table
  702	                                
  703	  F558    CD F5B2               	call	savstk			; create local stack
  704	  F55B    CD F5C4               	call	getadr			; hl: address of sector
  705	  F55E    11 F630               	ld	de,datbuf		; de: destination
  706	  F561    01 0080               	ld	bc,secsiz		; bc: size
  707	  F564    ED B0                 	ldir				; copy
  708	                                
  709	  F566    3E 01                 	ld	a,1			; restore bank1
  710	  F568    CD F5FF               	call	bank
  711	                                
  712	  F56B    21 F630               	ld	hl,datbuf		; hl: source
  713	  F56E    ED 5B F6B5            	ld	de,(dma)		; de: destination
  714	  F572    01 0080               	ld	bc,secsiz		; bc: size
  715	  F575    ED B0                 	ldir				; copy
  716	                                
  717	  F577    3E 00                 	ld	a,0			; return: no error
  718	  F579    CD F5BE               	call	resstk			; restore external stack
  719	  F57C    C9                    	ret
  720	                                
  721	                                
  722	                                ;----------------------------------------------------------------- Write ------
  723	                                ;
  724	                                ; Write
  725	                                ;
  726	                                ;	input:	none
  727	                                ;	output:	none
  728	                                ;
  729	                                
  730	  F57D    CD F5A8               write:	call	checkd			; drive C:?
  731	  F580    C2 EF0A               	jp	nz,owrite		;   no: old jump table
  732	                                
  733	  F583    CD F5B2               	call	savstk			; define local stack
  734	                                
  735	  F586    2A F6B5               	ld	hl,(dma)		; hl: source
  736	  F589    11 F630               	ld	de,datbuf		; de: destination
  737	  F58C    01 0080               	ld	bc,secsiz		; bc: size
  738	  F58F    ED B0                 	ldir				; copy
  739	                                
  740	  F591    CD F5C4               	call	getadr
  741	  F594    EB                    	ex	de,hl			; de: destination
  742	  F595    21 F630               	ld	hl,datbuf		; hl: source
  743	  F598    01 0080               	ld	bc,secsiz		; bc: size
  744	  F59B    ED B0                 	ldir				; copy
  745	                                
  746	  F59D    3E 01                 	ld	a,1			; restore bank1
  747	  F59F    CD F5FF               	call	bank
  748	                                
  749	  F5A2    3E 00                 	ld	a,0			; return: no error
  750	  F5A4    CD F5BE               	call	resstk			; restore external stack
  751	  F5A7    C9                    	ret
  752	                                
  753	                                	SUBTTL	Virtual-Disk: [BIOS.co-routines]
  754	                                	PAGE
VDISK	MACRO-80 3.44	09-Dec-81	PAGE	1-14
Virtual-Disk: [BIOS.co-routines]

  755	                                
  756	                                ;---------------------------------------------------------------- Checkd ------
  757	                                ;
  758	                                ; Checkd
  759	                                ;
  760	                                ;	input:
  761	                                ;		none
  762	                                ;	output:
  763	                                ;		Z-flag=1 if drive is 'C', else Z-flag=0.
  764	                                ;
  765	                                
  766	  F5A8    C5                    checkd:	push	bc
  767	  F5A9    47                    	ld	b,a
  768	  F5AA    3A F6B0               	ld	a,(drive)
  769	  F5AD    FE 02                 	cp	vd			; drive C:?
  770	  F5AF    78                    	ld	a,b
  771	  F5B0    C1                    	pop	bc
  772	  F5B1    C9                    	ret				; return: drive==C:
  773	                                
  774	                                
  775	                                ;---------------------------------------------------------------- Savstk ------
  776	                                ;
  777	                                ; Save external stack, create local stack
  778	                                ;
  779	                                
  780	  F5B2    21 0002               savstk:	ld	hl,0002			; save stackpointer, 
  781	  F5B5    39                    	add	hl,sp			;   returnaddress of 
  782	  F5B6    22 F6B7               	ld	(extstk),hl		;     calling routine removed
  783	  F5B9    E3                    	ex	(sp),hl			; get returnaddress of calling routine
  784	  F5BA    31 F800               	ld	sp,locstk		; create local stack
  785	  F5BD    E9                    	jp	(hl)			; return to caller
  786	                                
  787	                                
  788	                                ;---------------------------------------------------------------- Resstk ------
  789	                                ;
  790	                                ; Restore external stack.
  791	                                ;
  792	                                
  793	  F5BE    E1                    resstk:	pop	hl			; get return address
  794	  F5BF    ED 7B F6B7            	ld	sp,(extstk)		; restore external stackpointer
  795	  F5C3    E9                    	jp	(hl)			; return to caller
  796	                                	
  797	                                
  798	                                ;---------------------------------------------------------------- Getadr ------
  799	                                ;
  800	                                ; Getadr 	256 sectors/track
  801	                                ;
  802	                                ;	Select bank of current sector
  803	                                ;	Return bank-address of current sector
  804	                                ;
  805	                                ;	input:
  806	                                ;		none
  807	                                ;	output:
  808	                                ;		Reg.hl: address of sector (0..7f80)
  809	                                ;
  810	                                
  811	  F5C4                          getadr:
  812	                                
  813	                                ; Select bank
  814	  F5C4    3A F6B1               	ld	a,(track)		; low byte
  815	  F5C7    C6 02                 	add	a,vdboff		; Vdisktracks: >= bank2
  816	  F5C9    CD F5FF               	call	bank			; select bank
  817	                                
  818	                                ; Calculate address
  819	  F5CC    3A F6B3               	ld	a,(sector)		; low byte
  820	  F5CF    67                    	ld	h,a
  821	  F5D0    2E 00                 	ld	l,0
  822	  F5D2    CB 3C                 	srl	h
  823	  F5D4    CB 1D                 	rr	l			; hl: 0,S7..S1 : S0,0..0
  824	                                
  825	  F5D6    C9                    	ret
  826	                                
  827	                                	PAGE
VDISK	MACRO-80 3.44	09-Dec-81	PAGE	1-15
Virtual-Disk: [BIOS.co-routines]

  828	                                
  829	                                ;------------------------------------------------------------------ Bank ------
  830	                                ;
  831	                                ;	BANK: select a memory-bank
  832	                                ;
  833	                                ;	input:
  834	                                ;		Reg.a:	banknumber
  835	                                ;	output:
  836	                                ;		none
  837	                                ;
  838	                                
  839	  F5D7    02 00 02 00           bnkdat: db	2,0,2,0		; bank0
  840	  F5DB    02 00 02 01           	db	2,0,2,1		; bank1
  841	  F5DF    02 00 03 00           	db	2,0,3,0		; bank2
  842	  F5E3    02 00 03 01           	db	2,0,3,1		; bank3
  843	  F5E7    02 01 03 00           	db	2,1,3,0		; bank4
  844	  F5EB    02 01 03 01           	db	2,1,3,1		; bank5
  845	  F5EF    03 00 03 00           	db	3,0,3,0		; bank6
  846	  F5F3    03 00 03 01           	db	3,0,3,1		; bank7
  847	  F5F7    03 01 03 00           	db	3,1,3,0		; bank8
  848	  F5FB    03 01 03 01           	db	3,1,3,1		; bank9
  849	                                
  850	  F5FF                          bank:	
  851	                                
  852	                                IF capson EQ true
  853	                                
  854	                                	out	(9),a		; clear caps lock
  855	                                	cp	vdboff
  856	                                	jr	c,bank1
  857	                                	out	(8),a		; light caps lock
  858	                                bank1:
  859	                                
  860	                                ENDIF
  861	                                
  862	                                	
  863	                                ; get address of bank-select code
  864	  F5FF    06 00                 	ld	b,0		; clear reg b
  865	  F601    4F                    	ld	c,a
  866	  F602    CB 21                 	sla	c		; *4 (four byte/entry)
  867	  F604    CB 21                 	sla	c
  868	  F606    21 F5D7               	ld	hl,bnkdat
  869	  F609    09                    	add	hl,bc		; hl points to bankdat[index]
  870	                                
  871	                                ; select LS158 switch (Quad data selector)
  872	  F60A    4E                    	ld	c,(hl)
  873	  F60B    ED 79                 	out	(c),a		; set LS259 O0
  874	  F60D    23                    	inc	hl
  875	  F60E    4E                    	ld	c,(hl)
  876	  F60F    ED 79                 	out	(c),a		; set LS259 O1
  877	                                
  878	  F611    D3 04                 	out	(4),a		; toggle LS174 strobe (Hex D flipflop)
  879	  F613    D3 05                 	out	(5),a		;   LS259, O2:  _|~|_
  880	  F615    D3 04                 	out	(4),a
  881	                                
  882	                                ; select LS138 decoder
  883	  F617    23                    	inc	hl
  884	  F618    4E                    	ld	c,(hl)
  885	  F619    ED 79                 	out	(c),a		; set LS259 O0
  886	  F61B    23                    	inc	hl
  887	  F61C    4E                    	ld	c,(hl)
  888	  F61D    ED 79                 	out	(c),a		; set LS259 O1
  889	                                
  890	  F61F    C9                    	ret
  891	                                
  892	                                	SUBTTL	Virtual-Disk: [BIOS.storage]
  893	                                	PAGE
VDISK	MACRO-80 3.44	09-Dec-81	PAGE	1-16
Virtual-Disk: [BIOS.storage]

  894	                                
  895	                                ;--------------------------------------------------------------- Storage ------
  896	                                ;
  897	                                ; Virtual disk local variables 
  898	                                ;   (These don't have to be copied into Vdisk BIOS area)
  899	                                ;
  900	                                
  901	                                ;------------------------------------------------------------------- CSV ------
  902	                                ;
  903	                                ; Virtual-Disk directory check vector
  904	                                ;
  905	                                
  906	                                IF  cks EQ 0
  907	  0000                           csv	equ	0		; no check vector (0)
  908	                                ELSE
  909	                                 csv:	rept	cks		; cks byte check vector
  910	                                	db	0
  911	                                	endm
  912	                                ENDIF
  913	                                
  914	                                
  915	                                ;------------------------------------------------------------------- ALV ------
  916	                                ;
  917	                                ; Virtual-Disk storage allocation information buffer
  918	                                ;
  919	                                
  920	  F620                          alv:	ds	dsm/8+1		; 1 bit/bls [bit/k]
  921	                                
  922	                                
  923	                                ;------------------------------------------------------------ Databuffer ------
  924	                                ;
  925	                                ; Virtual-Disk databuffer		high memory data buffer
  926	                                ;
  927	                                
  928	  F630                          datbuf:	ds	secsiz
  929	                                
  930	                                
  931	                                ;------------------------------------------------------- Other variables ------
  932	                                ;
  933	                                ; Other variables
  934	                                ;
  935	                                
  936	  F6B0                          drive:	ds	1		; current drive
  937	  F6B1                          track:	ds	2		; current track
  938	  F6B3                          sector:	ds	2		; current sector
  939	  F6B5                          dma:	ds	2		; current dma address
  940	                                
  941	                                
  942	                                ;---------------------------------------------------- Local stackpointer ------
  943	                                ;
  944	                                ; Local stackpointer for read- and write-routines
  945	                                ;
  946	                                
  947	  F800                          locstk	equ	0F800H			; just below video-ram
  948	  F6B7                          extstk:	ds	2			; save external stackpointer here
  949	                                
  950	  F6B9                          vdbiosx:.dephase			; end of vdisk routines
  951	                                
  952	                                	SUBTTL	Vdisk: [format directory]
  953	                                	PAGE
VDISK	MACRO-80 3.44	09-Dec-81	PAGE	1-17
Vdisk: [format directory]

  954	                                
  955	                                ;---------------------------------------------------------------- Format ------
  956	                                ;
  957	                                ;	FORMAT Vdisk directory
  958	                                ;
  959	                                
  960	  03E7                          initlow:.phase	vdaddr	
  961	                                
  962	  F500                          init:
  963	  F500    3E 02                 format:	ld	a,dirsiz/bnksiz+vdboff	; format bank(s) with directory space
  964	  F502    CD F54B               format1:call	ibank
  965	  F505    CD F512               	call	format2			; format bank
  966	  F508    D6 01                 	sub	1
  967	  F50A    FE 01                 	cp	1
  968	  F50C    20 F4                 	jr	nz,format1
  969	  F50E    CD F54B               	call	ibank			; restore bank1
  970	  F511    C9                    	ret
