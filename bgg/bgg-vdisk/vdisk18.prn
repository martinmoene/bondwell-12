  994	  F527    02 00 02 01           	db	2,0,2,1		; bank1
  995	  F52B    02 00 03 00           	db	2,0,3,0		; bank2
  996	  F52F    02 00 03 01           	db	2,0,3,1		; bank3
  997	  F533    02 01 03 00           	db	2,1,3,0		; bank4
  998	  F537    02 01 03 01           	db	2,1,3,1		; bank5
  999	  F53B    03 00 03 00           	db	3,0,3,0		; bank6
 1000	  F53F    03 00 03 01           	db	3,0,3,1		; bank7
 1001	  F543    03 01 03 00           	db	3,1,3,0		; bank8
 1002	  F547    03 01 03 01           	db	3,1,3,1		; bank9
 1003	                                
