  476	                                
  477	  0205    2A 0219               	ld	hl,(oldsp)		; CCP stackpointer
  478	  0208    F9                    	ld	sp,hl
  479	                                
  480	                                
  481	                                ;------------------------------------------------- End of initialization ------
