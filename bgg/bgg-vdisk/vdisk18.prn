  517	  0222    C3                    	db	jump
  518	  0223    F544                  	dw	setsec
  519	  0225    C3                    	db	jump
  520	  0226    F54B                  	dw	setdma
  521	  0228    C3                    	db	jump
  522	  0229    F552                  	dw	read
  523	  022B    C3                    	db	jump
