  976	  F51C    3E E5                 	ld	a,0E5h
  977	  F51E    77                    	ld	(hl),a
  978	  F51F    ED B0                 	ldir
  979	  F521    F1                    	pop	af			; restore reg a
  980	  F522    C9                    	ret
