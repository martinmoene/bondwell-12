  503	  0219                          oldsp:	ds	2			; CCP stackpointer saved here
  504	  021B    00                    fopt:	db	false			; option '-F' used flag
  505	                                
  506	                                
  507	                                ;
  508	                                ; tabnew	new bios jump table
  509	                                ;
  510	                                
