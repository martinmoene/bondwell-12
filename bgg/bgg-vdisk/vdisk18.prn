VDisk: [Installation.global-constants]

  263	                                
  264	                                ;------------------------------------------------------ Global constants ------
  265	                                ;
  266	                                ;
  267	                                
  268	  0001                          true	equ	1			; boolean true
  269	  0000                          false	equ	0			; boolean false
  270	                                
  271	  0000                          capson	equ	false			; caps-lock doesn't indicate
  272	                                					;   virtual-disk activity
  273	                                
  274	  0002                          vd	equ	'C'-'A'			; code for drive 'C:'
  275	  0100                          vdsize	equ	256			; 256 k directory + data
  276	  0002                          vdboff	equ	2			; bank offset (first vdisk bank)
  277	  F500                          vdaddr	equ	0f500H			; Uninitialized memory used in BIOS 
  278	                                
  279	  0020                          bnksiz	equ	32			; Bondwell 12 Bank size: 32 k
  280	  0080                          secsiz	equ	128			; Sector size
  281	                                
  282	  D403                          ccp	equ	0d403H			; CCP entry
  283	  F2CD                          dirbuf	equ	0f2cdH			; directory buffer (also drive A: & B:)
  284	  F800                          stack	equ	0f800H			; Stack for this program
  285	                                
  286	  0005                          bdos	equ	5			; Bdos entry
  287	  0002                          pchr	equ	2			; Bdos print character function
  288	  0009                          pstr	equ	9			; Bdos print sting function
  289	                                
  290	  000D                          cr	equ	0dH			; carriage return code
  291	  000A                          lf	equ	0aH			; linefeed code
  292	                                
  293	                                
  294	                                IF1
  295	                                	.printx	Generating Virtual-disk initialization program.
  296	                                	.printx	System: Bondwell 12/14.
  297	                                	.printx	Operating system: CP/M 2.2.
  298	                                	IF capson EQ true
  299	                                	.printx	Caps-lock indicates V-disk activity (capson equ true).
  300	                                	ELSE
  301	                                	.printx	Caps-lock not used by this program (capson equ false).
  302	                                	ENDIF
  303	                                ENDIF
