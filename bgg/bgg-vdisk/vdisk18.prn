Vdisk: [Hardware extension]

   88	                                
   89	                                ;---------------------------------------------------- Hardware extension ------
   90	                                ;
   91	                                ;	Bondwell 12/14 Bank select and refresh
   92	                                ;	
   93	                                ;	Modifications to the Bondwell 12/14 Microprocessor board
   94	                                ;
   95	                                ;	To implement the memory extension with xx256 memory, instead of
   96	                                ;	the planned extension with xx64 memory chips, a couple of 
   97	                                ;	modifications has to be made to the Bondwell 12/14 main board.
   98	                                ;	The modifications concern the generation of row address A7 with 
   99	                                ;	refresh and row address A8 and column address A16 and a virtual
  100	                                ;	disk active signal capable of driving a LED.  The generation of
  101	                                ;	the extra signals is done by the 'Bank select & refresh' circuit.
  102	                                ;
  103	                                ;	First some wires on the main board have to be changed.  These 
  104	                                ;	       modifications are described below.
  105	                                ;	Second the wires from the 'Bank select & refresh' extension
  106	                                ;	       printed circuit board (10 pin Molex connector) are to be 
  107	                                ;	       connected to the points as described with the pcb layout.
  108	                                ;
  109	                                ;	
  110	                                ;	Wire cuts
  111	                                ;	---------
  112	                                ;
  113	                                ;	Signal		Cut between
  114	                                ;
  115	                                ;	Component side
  116	                                ;	CAS		IC52, pin 8  (74LS32)  --  IC53, pin 1  (xx256)
  117	                                ;	A8		IC60, pin 1  (xx256)   --  IC61, pin 15 ( 4164)
  118	                                ;	A7		IC60, pin 9  (xx256)   --  IC61, pin 9  ( 4164)
  119	                                ;
  120	                                ;	Solder side
  121	                                ;	A7		IC59, pin 9  (xx256)   --  IC44, pin 9  (74LS157)
  122	                                ;
  123	                                ;
  124	                                ;	New wires
  125	                                ;	---------
  126	                                ;	
  127	                                ;	Signal		Wire between
  128	                                ;
  129	                                ;	A7		IC44, pin 9  (74LS157) --  IC61, pin 9  (4164)
  130	                                ;	CAS		IC52, pin 8  (74LS32)  --  IC61, pin15  (4164)
  131	                                ;
  132	                                	PAGE
VDISK	MACRO-80 3.44	09-Dec-81	PAGE	1-3
Vdisk: [Hardware extension]

  133	                                
  134	                                ;	Bondwell 12/14 Bank select and refresh
  135	                                ;
  136	                                ;	Circuit diagram
  137	                                ;
  138	                                ;
  139	                                ;	** Generation of A8
  140	                                ;
  141	                                ;
  142	                                ;	   R/Cn    O-----------------------+
  143	                                ;					   |
  144	                                ;          O2      O---------+             |
  145	                                ;	                     |E            |S
  146	                                ;	                  +-----+       +-----+                       
  147	                                ;	               D1 |     | Q1  1A|     |                       
  148	                                ;	   O1      O------|     |-------|     |1Y                     
  149	                                ;	                  |LS174|       |LS158|O-------------------O A8 (xx256)
  150	                                ;	   O0      O------|     |-------|     |                       
  151	                                ;	               D2 |     | Q2  1B|     |                       
  152	                                ;	                  +-----+       +-----+	                
  153	                                ;
  154	                                ;
  155	                                ;	** Generation of A7 with refresh
  156	                                ;
  157	                                ;	                  +-----+       +-----------------+
  158	                                ;          MRQn    O------|     |    CLK| -               |                       
  159	                                ;	                  |LS02 |O-+----|  V    HEF4040   |                       
  160	                                ;          RFRn    O-+----|     |  |    |   -             |                       
  161	                                ;	             |    +-----+  |    +-----------------+                       
  162	                                ;	             |             |      |O7          |MR                        
  163	                                ;	             |  ^          |      |           ---                         
  164	                                ;	             |  |    4k7   |      |                                         
  165	                                ;	             |  +---====---+      |          LS151                        
  166	                                ;	             |                    |         +-----+                       
  167	                                ;	             |                    |   A7org |     |                       
  168	                                ;                    |                    |  O------|D3   |                       
  169	                                ;	             |                    |   A7new |     |                       
  170	                                ;	             |                    +---------|D2   |Y                      
  171	                                ;	             |                        A15   |     |--------O A7mem (xx256)
  172	                                ;	             |                       O---+--|D1   |                       
  173	                                ;	             |                           |  |     |                       
  174	                                ;	             |                           +--|D0   |---+ Strobe            
  175	                                ;	             |                              |     |---+ C                 
  176	                                ;	             |                              +-----+   |                   
  177	                                ;	             |                               |A |B   ---                  
  178	                                ;	             |                               |  |                         
  179	                                ;	             +-------------------------------+  |         
  180	                                ;					                |
  181	                                ;	  R/Cn     O------------------------------------+
  182	                                ;
  183	                                ;
  184	                                ;	LS151                     
  185	                                ;
  186	                                ;	C B A  n  Selected (A7mem)
  187	                                ;	--------------------------
  188	                                ;	0 0 0  0  A15 (Column)
  189	                                ;	0 0 1  1  A15 (Column)
  190	                                ;	0 1 0  2  A7new  (row)
  191	                                ;	0 1 1  3  A7org  (row)
  192	                                ;
  193	                                ;
  194	                                ;	** Virtual disk activity indication
  195	                                ;
  196	                                ;	                  +-----+       +-----------------+
  197	                                ;		      ----|     |       |     555         |  330E
  198	                                ;	   O2      O-+    |LS02 |O------|T               O|--====--O LED
  199	                                ;	              ----|     |       |        D Thr    |        O
  200	                                ;	                  +-----+    ^  +-----------------+        |
  201	                                ;	                             |     100k  | | 100nF         |
  202	                                ;	                             +-----====--+-+--U---+        |
  203	                                ;	                                                  |        |
  204	                                ;	                                                 ---      ---
  205	                                ;
  206	                                ;
  207	                                	PAGE
VDISK	MACRO-80 3.44	09-Dec-81	PAGE	1-4
Vdisk: [Hardware extension]

  208	                                
  209	                                ;	Bondwell 12/14 Bank select and refresh
  210	                                ;
  211	                                ;	Printed circuit board layout
  212	                                ;
  213	                                ;
  214	                                ;	         100k           330E
  215	                                ;	  100nF    100nF          4k7
  216	                                ;	+---------------------------------------+
  217	                                ;	| .     || | +-----+    |||           . |
  218	                                ;	|       |U = > 555 |    |UU  : LED      |
  219	                                ;	|       || | +-----+    |||             |
  220	                                ;	|  		                       	|
  221	                                ;	|   |   +----------+	+----------+	|
  222	                                ;	|   =   >  74LS158 |	>  HEF4040 |	|
  223	                                ;	|   |   +----------+	+----------+	|
  224	                                ;	|					|
  225	                                ;	|+5 .   +----------+	+--------+	|
  226	                                ;	| 0 .   >  74LS174 |	>  74LS02|	|
  227	                                ;	|       +----------+	+--------+	|
  228	                                ;	|					|
  229	                                ;	|	 ..........	+----------+	|
  230	                                ;	|	 1	  10	>  74LS151 |	|
  231	                                ;	|	            	+----------+	|
  232	                                ;	| .				      .	|
  233	                                ;	+---------------------------------------+
  234	                                ;		 ||||||||||
  235	                                ;		 ||||||||||____ MRQn
  236	                                ;		 |||||||||_____ RFRn
  237	                                ;		 ||||||||______ A15
  238	                                ;		 |||||||_______ A8
  239	                                ;		 ||||||________ A7org
  240	                                ;		 |||||_________ A7mem
  241	                                ;		 ||||__________ O2
  242	                                ;		 |||___________ O1
  243	                                ;		 ||____________ O0
  244	                                ;		 |_____________ R/Cn
  245	                                ;
  246	                                ;
  247	                                ;	10 pin Molex
  248	                                ;	------------------------------------------
  249	                                ;	  1.	brown	R/Cn    (IC44, LS157, p1 )
  250	                                ;	  2.    red	O0	(IC18, LS259, p4 )
  251	                                ;	  3.    orange	O1	(IC18, LS259, p5 )
  252	                                ;	  4.    yellow	O2	(IC18, LS259, p6 )
  253	                                ;	  5.    green	A7mem	(IC53, xx256, p9 )
  254	                                ;	  6.    blue	A7org	(IC35,   Z80, p37)
  255	                                ;	  7.    violet	A8	(IC53, xx256, p1 )
  256	                                ;	  8.    grey	A15	(IC44, LS157, p11)
  257	                                ;	  9.    white	RFRn	(IC35,   Z80, p28)
  258	                                ;	 10.    black	MRQn	(=R/Cn)
  259	                                ;
