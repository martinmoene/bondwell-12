  307	                                
  308	                                ;------------------------------------------------------------- Main line ------
  309	                                ;
  310	                                ;
  311	                                
  312	                                	org	100h			; CP/M programs usually start here
  313	  0100    C3 018A               	jp	start			; Skip opening message
  314	                                
  315	                                
  316	                                ;
  317	                                ; Copyright
  318	                                ;
  319	                                
  320	  0103    3C 43 6F 70           	db	'<Copyright 1987 M.J. Moene>'
  321	  0107    79 72 69 67           
  322	  010B    68 74 20 31           
  323	  010F    39 38 37 20           
  324	  0113    4D 2E 4A 2E           
  325	  0117    20 4D 6F 65           
  326	  011B    6E 65 3E              
  327	                                
  328	                                
  329	                                ;
  330	                                ; Opening message
  331	                                ;
  332	                                
  333	  011E    0D 0A                 msg:	db	cr,lf
  334	  0120    20 20 3C 20           	db	'  < VDISK >',cr,lf,lf
  335	  0124    56 44 49 53           
  336	  0128    4B 20 3E 0D           
  337	  012C    0A 0A                 
  338	  012E    20 20 42 6F           	db	'  Bondwell 12/14',cr,lf
  339	  0132    6E 64 77 65           
  340	  0136    6C 6C 20 31           
  341	  013A    32 2F 31 34           
  342	  013E    0D 0A                 
  343	  0140    20 20 32 35           	db	'  254 k Virtual Disk',cr,lf
  344	  0144    34 20 6B 20           
  345	  0148    56 69 72 74           
  346	  014C    75 61 6C 20           
  347	  0150    44 69 73 6B           
  348	  0154    0D 0A                 
  349	  0156    20 20 36 34           	db	'  64 Directory entries',cr,lf
  350	  015A    20 44 69 72           
  351	  015E    65 63 74 6F           
  352	  0162    72 79 20 65           
  353	  0166    6E 74 72 69           
  354	  016A    65 73 0D 0A           
  355	  016E    20 20 56 65           	db	'  Version 1.8 - 4 mar 1987',cr,'$'
  356	  0172    72 73 69 6F           
  357	  0176    6E 20 31 2E           
  358	  017A    38 20 2D 20           
  359	  017E    34 20 6D 61           
  360	  0182    72 20 31 39           
  361	  0186    38 37 0D 24           
  362	                                
  363	  018A    21 0000               start:	ld	hl,0			; save current stackpointer
  364	  018D    39                    	add	hl,sp
  365	  018E    22 0219               	ld	(oldsp),hl
  366	  0191    31 F800               	ld	sp,stack		; define new stack
  367	                                
  368	  0194    0E 09                 	ld	c,pstr			; print opening message
  369	  0196    11 011E               	ld	de,msg
  370	  0199    CD 0005               	call	bdos
  371	                                
  372	                                
  373	                                ;------------------------------------------------------ Check for option ------
  374	                                ;
  375	                                ; Option	vdsk -f		(vdisk format & initialize c-drive routines)
  376	                                ;		vdsk		(initialize c-drive routines only)
  377	                                ;
  378	                                ;		Remark:		Option only usefull if directory isn't
  379	                                ;				cleared at executing vdsk (without -f).
  380	                                ;
  381	                                
  382	  019C    21 0080               opt:	ld	hl,80H			; Commandline tail: length,char,...
  383	  019F    7E                    	ld	a,(hl)			; length
  384	  01A0    FE 00                 	cp	0			; option added?
  385	  01A2    28 14                 	jr	z,optx			;   no: skip
  386	  01A4    23                    	inc	hl			;   yes: check for '-F'  (skip space)
  387	  01A5    23                    	inc	hl
  388	  01A6    7E                    	ld	a,(hl)
  389	  01A7    FE 2D                 	cp	'-'
VDISK	MACRO-80 3.44	09-Dec-81	PAGE	1-7
VDisk: [Installation.main-line]

  390	  01A9    20 0D                 	jr	nz,optx			; no '-'
  391	  01AB    23                    	inc	hl
  392	  01AC    7E                    	ld	a,(hl)
  393	  01AD    FE 46                 	cp	'F'
  394	  01AF    20 07                 	jr	nz,optx			; no 'F'
  395	                                
  396	  01B1    3E 01                 	ld	a,true			; fopt flag= true
  397	  01B3    32 021B               	ld	(fopt),a
  398	                                
  399	  01B6    18 15                 	jr	movfor			; option is '-F'
  400	  01B8    18 29                 optx:	jr	movpgm			; no option
  401	                                	
  402	                                
  403	                                ;---------------------------------------------------------------- Format ------
  404	                                ;
  405	                                ; Format
  406	                                ;
  407	                                ;		Format virtual disk directory
  408	                                ;
  409	                                
  410	  01BA    0A 20 20 46           formsg:	db	lf,'  Formatting ...',cr,'$'
  411	  01BE    6F 72 6D 61           
  412	  01C2    74 74 69 6E           
  413	  01C6    67 20 2E 2E           
  414	  01CA    2E 0D 24              
  415	                                
  416	  01CD    0E 09                 movfor:	ld	c,pstr			; print 'Formatting'
  417	  01CF    11 01BA               	ld	de,formsg
  418	  01D2    CD 0005               	call	bdos
  419	                                
  420	  01D5    21 03E7               	ld	hl,initlow		; move format program to high memory
  421	  01D8    11 F500               	ld	de,vdaddr
  422	  01DB    01 0072               	ld	bc,initx-init		; init end - init begin: #bytes to move
  423	  01DE    ED B0                 	ldir				; move
  424	                                
  425	  01E0    CD F500               	call	format			; format Vdisk directory
  426	                                
  427	                                
  428	                                ;---------------------------------------------------- Move bios routines ------
  429	                                ;
  430	                                ; movpgm	move vdisk program to high RAM
  431	                                ;
  432	                                
  433	  01E3    21 022E               movpgm:	ld	hl,vdbiosl		; vdbios low address: where to move from
  434	  01E6    11 F500               	ld	de,vdaddr		; destination: high memory (>7fffH)
  435	  01E9    01 01B9               	ld	bc,vdbiosx-vdbios	; program size
  436	  01EC    ED B0                 	ldir
  437	                                
  438	                                
  439	                                ;-------------------------------------------- Reroute BIOS warmboot-tail ------
  440	                                ;
  441	                                ; wboot check for legal drive specification
  442	                                ; change wboot  jp ccp  to  jp vdwbt
  443	                                ;
  444	                                
  445	  EAF9                          wbjccp	equ	0eaf9H			; address of jp ccp at end of bios wboot
  446	                                
  447	  01EE    21 F51F               	ld	hl,vdwbt		; Virtual disk warmboot routine tail
  448	  01F1    22 EAF9               	ld	(wbjccp),hl		; change original wboot jump CCP to
  449	                                					;   jump vdwbt
  450	                                
  451	                                
  452	                                ;--------------------------------------------- Overwrite BIOS jump-table ------
  453	                                ;
  454	                                ; movjpn	move new jump table
  455	                                ;
  456	                                ;		Replace old bios jump table by new table (tabnew)
  457	                                ;
  458	                                
  459	  0001                          jpoadd	equ	1			; address of old jump table
  460	  0018                          jpbegin	equ	24			; jp seldsk - jp wboot
  461	                                
  462	                                
  463	  01F4    ED 4B 0001            	ld	bc,(jpoadd)
  464	  01F8    21 0018               	ld	hl,jpbegin
  465	  01FB    09                    	add	hl,bc
  466	  01FC    EB                    	ex	de,hl			; de: destination
  467	  01FD    21 021C               	ld	hl,tabnew		; hl: source
  468	  0200    01 0012               	ld	bc,tabnewx-tabnew	; bc: size
  469	  0203    ED B0                 	ldir				; copy
  470	                                
  471	                                
  472	                                ;-------------------------------------------------- Restore stackpointer ------
  473	                                ;
